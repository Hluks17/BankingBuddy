<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F6F9">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- TITLE -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Spending Overview"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#0A2540"/>

        <!-- TOTAL -->
        <TextView
            android:id="@+id/totalText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Total: R 0"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#1B6CA8"
            android:layout_marginTop="10dp"/>

        <!-- PIE CHART -->
        <com.github.mikephil.charting.charts.PieChart
            android:id="@+id/pieChart"
            android:layout_width="match_parent"
            android:layout_height="260dp"
            android:layout_marginTop="20dp"/>

        <!-- ADD BUTTON -->
        <Button
            android:id="@+id/btnAddExpense"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="Add Expense"
            android:backgroundTint="#1B6CA8"
            android:textColor="#FFFFFF"
            android:layout_marginTop="20dp"/>

        <!-- 🔥 RESET BUTTON (NEW) -->
        <Button
            android:id="@+id/btnResetExpenses"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="Reset Expenses"
            android:backgroundTint="#D32F2F"
            android:textColor="#FFFFFF"
            android:layout_marginTop="10dp"/>

        <!-- LIST -->
        <LinearLayout
            android:id="@+id/expenseContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="20dp"/>

    </LinearLayout>

</ScrollView>
