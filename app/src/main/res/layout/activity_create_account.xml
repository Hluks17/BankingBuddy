<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F6F9">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- TITLE -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Create Savings Account"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#0A2540"
            android:layout_marginBottom="20dp"/>

        <!-- ACCOUNT NAME -->
        <EditText
            android:id="@+id/etAccountName"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:hint="Account Name"
            android:background="@android:drawable/edit_text"
            android:padding="10dp"
            android:layout_marginBottom="16dp"/>

        <!-- BALANCE -->
        <EditText
            android:id="@+id/etBalance"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:hint="Starting Balance"
            android:inputType="numberDecimal"
            android:background="@android:drawable/edit_text"
            android:padding="10dp"
            android:layout_marginBottom="16dp"/>

        <!-- ACCOUNT TYPE -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select Account Type"
            android:textStyle="bold"
            android:layout_marginBottom="10dp"/>

        <RadioGroup
            android:id="@+id/radioGroupType"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <RadioButton
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Access Anytime"/>

            <RadioButton
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="7 Days Notice"/>

            <RadioButton
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="32 Days Notice"/>
        </RadioGroup>

        <!-- CREATE BUTTON -->
        <Button
            android:id="@+id/btnCreate"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="Create Account"
            android:layout_marginTop="20dp"
            android:backgroundTint="#1B6CA8"
            android:textColor="#FFFFFF"/>

    </LinearLayout>
</ScrollView>
